generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String            @id @default(cuid())
  name              String?
  email             String            @unique
  emailVerified     DateTime?
  isVerified        Boolean           @default(false)
  verificationToken String?
  password          String?
  googleId          String?           @unique
  image             String?
  plan              String            @default("FREE")
  identityDocUrl   String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  expensesPaid     Expense[]         @relation("Payer")
  splits           ExpenseSplit[]
  flights          Flight[]
  flightPass       FlightPassenger[]
  stayPass         StayMember[]
  carRentalPass    CarRentalMember[]
  ownedGroups      Group[]           @relation("GroupOwner")
  memberships      Membership[]
  votes            Vote[]
}

model Group {
  id           String          @id @default(cuid())
  name         String
  description  String?
  image        String?
  type         String          @default("group")
  inviteCode   String          @unique
  ownerId      String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  carRentals   CarRental[]
  destinations Destination[]
  expenses     Expense[]
  flights      Flight[]
  owner        User            @relation("GroupOwner", fields: [ownerId], references: [id])
  insurances   Insurance[]
  itinerary    ItineraryItem[]
  members      Membership[]
  stays        Stay[]
}

model Membership {
  id       String   @id @default(cuid())
  userId   String
  groupId  String
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())
  group    Group    @relation(fields: [groupId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([userId, groupId])
}

model Destination {
  id          String  @id @default(cuid())
  groupId     String
  name        String
  description String?
  image       String?
  status      String  @default("SUGGESTED")
  suggestedBy String
  group       Group   @relation(fields: [groupId], references: [id])
  votes       Vote[]
}

model ItineraryItem {
  id       String   @id @default(cuid())
  groupId  String
  title    String
  time     String?
  location String?
  date     DateTime
  type     String   @default("activity")
  group    Group    @relation(fields: [groupId], references: [id])
}

model Flight {
  id            String            @id @default(cuid())
  groupId       String
  creatorId     String
  number        String?
  airline       String?
  departureTime DateTime?
  arrivalTime   DateTime?
  origin        String?
  destination   String?
  createdAt     DateTime          @default(now())
  creator       User              @relation(fields: [creatorId], references: [id])
  group         Group             @relation(fields: [groupId], references: [id])
  passengers    FlightPassenger[]
}

model FlightPassenger {
  id              String   @id @default(cuid())
  flightId        String
  userId          String
  boardingPassUrl String?
  identityDocUrl  String?
  createdAt       DateTime @default(now())
  flight          Flight   @relation(fields: [flightId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id])

  @@unique([flightId, userId])
}

model Stay {
  id                String       @id @default(cuid())
  groupId           String
  name              String
  address           String?
  lat               Float?
  lng               Float?
  googlePlaceId     String?
  checkIn           DateTime?
  checkOut          DateTime?
  bookingVoucherUrl String?
  createdAt         DateTime     @default(now())
  group             Group        @relation(fields: [groupId], references: [id])
  members           StayMember[]
}

model StayMember {
  id        String   @id @default(cuid())
  stayId    String
  userId    String
  createdAt DateTime @default(now())
  stay      Stay     @relation(fields: [stayId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([stayId, userId])
}

model Vote {
  id            String      @id @default(cuid())
  userId        String
  destinationId String
  value         Int         @default(1)
  destination   Destination @relation(fields: [destinationId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@unique([userId, destinationId])
}

model Expense {
  id          String         @id @default(cuid())
  groupId     String
  description String
  amount      Float
  currency    String         @default("BRL")
  date        DateTime       @default(now())
  paidById    String
  group       Group          @relation(fields: [groupId], references: [id])
  paidBy      User           @relation("Payer", fields: [paidById], references: [id])
  splits      ExpenseSplit[]
}

model ExpenseSplit {
  id        String  @id @default(cuid())
  expenseId String
  userId    String
  amount    Float
  shares    Int     @default(1)
  isPaid    Boolean @default(false)
  expense   Expense @relation(fields: [expenseId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
}

model PendingUser {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String
  password          String
  verificationToken String
  createdAt         DateTime @default(now())
}

model CarRental {
  id               String            @id @default(cuid())
  groupId          String
  company          String
  model            String?
  pickupLocation   String?
  pickupTime       DateTime?
  dropoffLocation  String?
  dropoffTime      DateTime?
  confirmationCode String?
  createdAt        DateTime          @default(now())
  group            Group             @relation(fields: [groupId], references: [id])
  members          CarRentalMember[]
}

model CarRentalMember {
  id                String    @id @default(cuid())
  carRentalId       String
  userId            String
  bookingVoucherUrl String?
  createdAt         DateTime  @default(now())
  carRental         CarRental @relation(fields: [carRentalId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id])

  @@unique([carRentalId, userId])
}

model Insurance {
  id           String    @id @default(cuid())
  groupId      String
  provider     String
  policyNumber String?
  startDate    DateTime?
  endDate      DateTime?
  contactInfo  String?
  createdAt    DateTime  @default(now())
  group        Group     @relation(fields: [groupId], references: [id])
}
